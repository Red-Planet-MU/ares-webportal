{{page-title 'Roster'" | Red Planet"}}
<h1>Roster</h1>

<p>The roster contains ready-made characters.  Some have been played before, as indicated by a <span class="badge bg-info">Previously Played</span> tag.  Roster characters require an application. Please use the <LinkTo @route="tour">Tour</LinkTo> function to get started, then come back here to submit a claim on the roster you'd like to play.</p>
<br>
{{#each this.model.roster as |group|}}

    {{#each group.chars as |char|}}
    
    <div class="roster-wrap">
    
        <div class="roster-image-wrap">
           <CharIcon @char={{char}} />           
        </div>

        <div class="roster-info">
          <div class="roster-char-title">{{char.profile_title}}</div>
          
          <p><AnsiFormat @text={{char.roster_notes}} /></p>
     
    
          {{#each-in char.fields as |field value| }}
          <div><b>{{field}}:</b> {{value}}</div>
          {{/each-in}}
            <br>
            
           <div class="roster-char-warnings">
       
             {{#if char.app_pending }}
             <span class="badge bg-danger-custom">App Pending</span>
             {{/if}}
       
             {{#if char.previously_played}}
             <span class="badge bg-info">Previously Played</span>
             {{/if}}

             {{#if char.app_required}}
             <span class="badge bg-warning-custom">App Required</span>
             {{/if}}
      
           </div>
      </div>
      
      <div class="roster-buttons">  
         <LinkTo @route="char" @model={{char.name}} class="btn btn-secondary">Profile</LinkTo>
         {{#if (not char.app_pending)}}
          {{#if this.isAuthenticated}}
            <LinkTo @route="roster-claim" @model={{char.id}} class="btn btn-primary">Claim</LinkTo>
          {{else}}
            <LinkTo @route="roster-claim" @model={{char.id}} class="btn btn-primary" disabled="true">Claim</LinkTo>
          {{/if}}
         {{/if}}
       </div>
        
    </div>
    
    {{/each}}

{{/each}}

{{outlet}}